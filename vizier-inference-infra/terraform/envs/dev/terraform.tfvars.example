aws_region                 = "us-east-1"
project_name               = "vizier-inference"
environment                = "dev"
single_az_mode             = false
enable_nat_gateway         = true
enable_vpc_endpoints       = false
django_allowed_hosts       = "*"
backend_image_tag          = "latest"
biomedparse_image_tag      = "v2-20260317-164247-03338460"
manage_backend_ecr_repository     = false
external_backend_ecr_repository_url = "123456789012.dkr.ecr.us-east-1.amazonaws.com/vizier-backend-dev"
manage_biomedparse_ecr_repository = false
external_biomedparse_ecr_repository_url = "123456789012.dkr.ecr.us-east-1.amazonaws.com/biomedparse"
biomedparse_image_override = "123456789012.dkr.ecr.us-east-1.amazonaws.com/biomedparse:v2-20260317-164247-03338460"
ecr_force_delete           = false

rds_password      = "change-me"
django_secret_key = "change-me"
rds_skip_final_snapshot = false
# recomendado para evitar conflito de snapshot ao destruir/recriar:
# rds_final_snapshot_identifier = "vizier-postgres-dev-final-20260318"
rds_deletion_protection = true
api_desired_count = 2
worker_desired_count = 2
rds_backup_retention_days = 14

inference_api_bearer_token = ""
enable_stripe_billing = true
stripe_secret_key = "sk_test_change_me"
stripe_webhook_secret = "whsec_change_me"
# opcional:
# stripe_product_id = "prod_xxx"
# stripe_price_id_individual_monthly = "price_xxx"
# stripe_price_id_individual_annual = "price_xxx"
# stripe_price_id_clinic_monthly = "price_xxx"
# stripe_price_id_clinic_yearly = "price_xxx"
# stripe_price_lookup_key_individual_monthly = "individual_monthly"
# stripe_price_lookup_key_individual_annual = "individual_annual"

frontend_upload_allowed_origins = [
  "https://dev.example.com",
]

stripe_allowed_redirect_origins = [
  "https://dev.example.com",
]

alb_ingress_cidrs = [
  "0.0.0.0/0",
]

# opcional para endpoint estável da API:
# api_custom_domain_name = "api-dev.viziermed.com"
# api_route53_zone_id = "Z123EXAMPLE"
# api_cloudfront_certificate_arn = ""
