aws_region                 = "us-east-1"
project_name               = "vizier-inference"
environment                = "prod"
single_az_mode             = false
enable_nat_gateway         = true
enable_vpc_endpoints       = false
django_allowed_hosts       = "*"
backend_image_tag          = "latest"
biomedparse_image_tag      = "v2-20260317-164247-03338460"
manage_backend_ecr_repository       = false
external_backend_ecr_repository_url = "123456789012.dkr.ecr.us-east-1.amazonaws.com/vizier-backend-prod"
manage_biomedparse_ecr_repository   = false
external_biomedparse_ecr_repository_url = "123456789012.dkr.ecr.us-east-1.amazonaws.com/biomedparse"
biomedparse_image_override = "123456789012.dkr.ecr.us-east-1.amazonaws.com/biomedparse:v2-20260317-164247-03338460"
ecr_force_delete           = false

rds_password      = "change-me"
django_secret_key = "change-me"
rds_skip_final_snapshot = false
# rds_final_snapshot_identifier = "vizier-postgres-prod-final-20260314"

inference_api_bearer_token = ""
enable_stripe_billing = true
stripe_secret_key = "sk_live_change_me"
stripe_webhook_secret = "whsec_change_me"
